{
  "name": "google-sheets-auto-sync",
  "version": "1.0.0",
  "description": "Automatically syncs targeted rows from one Google Sheet to another using the Google Sheets API. Supports dynamic tab discovery, upsert logic, and permanent archiving.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "sync:once": "node src/index.js --once",
    "dev": "nodemon src/index.js",
    "test": "node src/test.js"
  },
  "keywords": [
    "google-sheets",
    "sync",
    "automation",
    "crm",
    "node"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.1",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
